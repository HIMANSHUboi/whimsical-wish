{
  "version": 2,
  "outputDirectory": "dist/client",
  "cleanUrls": true,
  "functions": {
    "api/server.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/|.*\\..*$).*)",
      "destination": "/api/server"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
